## Server environment variables (example)
## Copy to `.env` and fill values for local dev.

NODE_ENV=development
PORT=4000

# Frontend URL for CORS
CLIENT_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/socratic?schema=public

# Redis (queues, rate limiting, cache)
REDIS_URL=redis://localhost:6379

# Chroma (vector DB)
CHROMA_URL=http://localhost:8000

# LLM
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Uploads (leave empty for local dev initially)
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
